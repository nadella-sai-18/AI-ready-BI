# FastAPI backend base URL
VITE_API_URL=http://localhost:8000

# --- BI integrations (opened in a new browser tab from the app) ---
# Existing Metabase instance (do NOT recreate). Base URL:
VITE_METABASE_URL=http://localhost:3000
# Optional: link the "Open Metabase Dashboard" button straight to a specific
# dashboard, e.g. http://localhost:3000/dashboard/1 . Falls back to the base URL.
VITE_METABASE_DASHBOARD_URL=

# Self-hosted MinusX OSS (see infra/minusx/). Runs on 3100 because Metabase
# uses 3000. Leave blank to use the default http://localhost:3100.
VITE_MINUSX_URL=http://localhost:3100
