# =====================================================================
# AWS EC2 deployment — copy to `.env` and fill in.  cp .env.example .env
# =====================================================================

# ---- Public domains (create DNS A-records pointing to your EC2 Elastic IP) ----
# One subdomain per app. No domain? Use nip.io with your Elastic IP,
# e.g. METABASE_DOMAIN=metabase.203-0-113-45.nip.io  (dashes for the IP).
METABASE_DOMAIN=metabase.yourdomain.com
MINUSX_DOMAIN=minusx.yourdomain.com

# ---- Let's Encrypt (issues the HTTPS certificates) ----
LETSENCRYPT_EMAIL=you@example.com

# ---- Metabase's OWN metadata database (runs locally on the EC2 instance) ----
# Stores Metabase's dashboards/settings ONLY. NOT your college data. Your
# college data lives in Railway Postgres and is added as a data source in the
# Metabase UI after startup (see README).
MB_DB_DBNAME=metabaseapp
MB_DB_USER=mbadmin
MB_DB_PASS=CHANGE_ME_strong_password

# ---- MinusX (OSS) ----
# LLM provider: MinusX uses Anthropic (Claude). This is the ONLY provider it
# needs by default (no OpenAI key required). Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Session signing secret. Generate with:  openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME_with_a_long_random_string

# ---------------------------------------------------------------------
# The EXISTING Railway PostgreSQL (college data) is NOT set here. You add it as
# a DATA SOURCE inside Metabase & MinusX after they start, using the Railway
# PUBLIC connection string, e.g.:
#   postgresql://postgres:PASS@crossover.proxy.rlwy.net:32097/railway
# (Metabase: Use SSL = ON / MinusX: add ?sslmode=disable — see README.)
# ---------------------------------------------------------------------
