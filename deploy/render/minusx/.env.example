# MinusX on Render — environment variables
# (If you use render.yaml, NEXTAUTH_SECRET is generated and ANTHROPIC_API_KEY /
#  NEXTAUTH_URL are marked to fill in the dashboard. This file lists everything
#  for the MANUAL "New Web Service from image" path.)

NODE_ENV=production

# MinusX's own storage (embedded — NOT college data)
DB_TYPE=pglite
PGLITE_DATA_DIR=/app/data/pglite
BASE_DUCKDB_DATA_PATH=/app
ANALYTICS_DB_DIR=/app/data/analytics

# Port MinusX (Next.js) listens on; tell Render to route here
PORT=3000

# --- LLM provider: MinusX uses Anthropic (Claude) ---
# Your Claude API key (from https://console.anthropic.com). This is the ONLY
# provider MinusX needs by default. (No OpenAI key required.)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Session signing secret — generate with:  openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME_with_a_long_random_string

# Public URL — set AFTER first deploy to your real MinusX URL (fixes login/callbacks)
NEXTAUTH_URL=https://your-minusx.onrender.com

# ---------------------------------------------------------------------
# Your COLLEGE DATA (Railway Postgres) is added inside the MinusX UI as a
# PostgreSQL data source (Connection String tab), e.g.:
#   postgresql://postgres:PASS@crossover.proxy.rlwy.net:32097/railway?sslmode=disable
# ---------------------------------------------------------------------
