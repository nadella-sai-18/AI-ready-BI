# Metabase on Render — environment variables
# (If you use render.yaml, most of these are set automatically. This file lists
#  everything for the MANUAL "New Web Service from image" path.)

# --- Metabase's OWN metadata database (a Render Postgres you create) ---
# Get these from the Render Postgres you add (Info tab -> Connections).
MB_DB_TYPE=postgres
MB_DB_HOST=<render-postgres-internal-host>
MB_DB_PORT=5432
MB_DB_DBNAME=metabaseapp
MB_DB_USER=<render-postgres-user>
MB_DB_PASS=<render-postgres-password>

# --- Port Render routes to (leave 10000; Render's default) ---
MB_JETTY_PORT=10000

# --- Memory cap so it fits the instance (free=512MB -> 400m; bigger plan -> 1g) ---
JAVA_TOOL_OPTIONS=-Xmx400m

# --- Public URL — set AFTER the first deploy, to your real Metabase URL ---
MB_SITE_URL=https://your-metabase.onrender.com

# ---------------------------------------------------------------------
# Your COLLEGE DATA (Railway Postgres) is NOT set here — you add it as a
# DATA SOURCE in the Metabase UI (Admin -> Databases -> Add), using the
# Railway PUBLIC URL, e.g.:
#   host: crossover.proxy.rlwy.net  port: 32097  db: railway  user: postgres
#   password: <from your Railway DB>   Use SSL: ON
# ---------------------------------------------------------------------
