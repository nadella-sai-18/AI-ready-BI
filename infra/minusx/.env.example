# Self-hosted MinusX — copy this file to `.env` and fill in the values.
#   cp .env.example .env

# Your Anthropic (Claude) API key. MinusX is "Claude Code for data" and needs this.
# Get one at https://console.anthropic.com/  (key looks like sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Any long random string used to sign MinusX sessions.
# Generate one with:  openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME_with_a_long_random_string

# Host port for the MinusX web UI (Metabase already uses 3000).
FRONTEND_PORT=3100
