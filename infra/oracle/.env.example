# =====================================================================
# Oracle VM deployment — copy to `.env` and fill in.  cp .env.example .env
# =====================================================================

# ---- Public domains (create DNS A-records pointing to your VM's public IP) ----
# Two subdomains, one per app. If you have no domain, use nip.io with your IP,
# e.g. METABASE_DOMAIN=metabase.203-0-113-45.nip.io  (dashes for the IP).
METABASE_DOMAIN=metabase.yourdomain.com
MINUSX_DOMAIN=minusx.yourdomain.com

# ---- Let's Encrypt (used to issue the HTTPS certificates) ----
LETSENCRYPT_EMAIL=you@example.com

# ---- Metabase's OWN metadata database (runs locally on the VM) ----
# This stores Metabase's dashboards/settings ONLY. It is NOT your college data.
# Your college data lives in Railway Postgres and is added as a data source in
# the Metabase UI after startup (see README, "Connect the college database").
MB_DB_DBNAME=metabaseapp
MB_DB_USER=mbadmin
MB_DB_PASS=CHANGE_ME_strong_password

# ---- MinusX (OSS) ----
# Your Anthropic (Claude) API key — MinusX uses Claude as its engine.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Any long random string. Generate with:  openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_ME_with_a_long_random_string

# ---------------------------------------------------------------------
# NOTE — the EXISTING Railway PostgreSQL (your college data) is NOT set here.
# You add it as a DATA SOURCE inside Metabase and MinusX after they start,
# using the Railway PUBLIC connection string, e.g.:
#   postgresql://postgres:PASS@crossover.proxy.rlwy.net:32097/railway
# (Metabase: add ?ssl=true / MinusX: add ?sslmode=disable — see README.)
# ---------------------------------------------------------------------
